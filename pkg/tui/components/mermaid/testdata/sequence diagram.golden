                    ╭────────╮                                        ╭────────╮
                    │ Client │                                        │ Server │
                    ╰────┬───╯                                        ╰────┬───╯
                         │                                                 │
                         │          ╭─────────────────────────╮            │
                         │          │ TCP three-way handshake │            │
                         │          ╰─────────────────────────╯            │
                         │                                                 │
                         ├────────────────── SYN, Seq = x ─────────────────▶
                         │                                                 │
                         │                                                 │ ╭──────────────╮
                         │                                                 │ │ SYN received │
                         │                                                 │ ╰──────────────╯
                         │                                                 │
                         ◀───────── SYN-ACK, Seq = y, Ack = x + 1 ─────────┤
                         │                                                 │
╭──────────────────────────────────╮                                       │
│ Server acknowledges client's SYN │                                       │
╰──────────────────────────────────╯                                       │
                         │                                                 │
                         ├───────── ACK, Seq = x + 1, Ack = y + 1 ─────────▶
                         │                                                 │
                         │           ╭────────────────────────╮            │
                         │           │ Connection established │            │
                         │           ╰────────────────────────╯            │
                         │                                                 │
                         ├─────────────── Data, Seq = x + 1 ───────────────▶
                         │                                                 │
                         ◀───────── ACK, Ack = next expected byte ─────────┤
                         │                                                 │